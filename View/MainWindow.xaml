<Window x:Class="ReferenceApplicationArchitecture.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wspolbiezny Stol Bilardowy" Height="520" Width="900" MinWidth="700" MinHeight="420">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Liczba kul:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox x:Name="BallCountBox" Width="80" Height="28" VerticalContentAlignment="Center" Text="12" Margin="0,0,8,0" />
            <Button Content="Start" Width="90" Height="28" Margin="0,0,8,0" Click="OnStartSimulation" />
            <Button Content="Stop" Width="90" Height="28" Click="OnStopSimulation" />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#2D2D2D" BorderThickness="2" CornerRadius="6" Background="#1F6A31">
            <Canvas x:Name="TableCanvas" Margin="8" Background="#2F8C45" />
        </Border>

        <TextBlock x:Name="ErrorText" Grid.Row="2" Foreground="Red" Margin="0,10,0,0" />
    </Grid>
</Window>
